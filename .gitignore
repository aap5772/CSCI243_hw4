#########################################################
# list taken from github and modified for csci243 use
# student: put patterns of file content to ignore in here
# for example, put the names of binary programs to
# stop from versioning them in Git.
#########################################################

##################
# RCS, CVS files #
##################
*,v

# Thu Dec 17 16:33:28 EST 2020
#########################################################
# Compiled source #
###################
*.a
*.class
*.com
*.dll
*.exe
*.i
*.o
*.pyc
*.s
*.so

# Packages #
############
# it's better to unpack these files and commit the raw source
# git has its own built in compression methods
*.7z
*.dmg
*.gz
*.iso
*.jar
*.rar
*.tar
*.zip

# Logs and databases #
######################
*.log
*.sql
*.sqlite

# OS generated files #
######################
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.Trash
Thumbs.db

